<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SMDP Taylor sville</title>

    <!-- Our compiled Tailwind CSS — generated by 'npm run build:css'
       This is the file Tailwind wrote into /public/style.css -->
    <link rel="stylesheet" href="/style.css" />

    <!-- Font Awesome for icons — loaded from CDN
       Gives us <i> tags for Facebook, Instagram, YouTube, Heart icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />

    <!-- Google Fonts — Cormorant Garamond for elegant headings -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="min-h-screen bg-amber-50 flex items-center justify-center px-4 py-10"
  >
    <!--
  min-h-screen   → minimum height = full screen height
  bg-amber-50    → very light warm background color
  flex           → use flexbox layout
  items-center   → center children vertically
  justify-center → center children horizontally
  px-4 py-10     → padding: horizontal 1rem, vertical 2.5rem
-->

    <div class="w-full max-w-sm flex flex-col items-center gap-6">
      <!--
    w-full      → take full width of parent
    max-w-sm    → but never wider than 384px (mobile-friendly)
    flex flex-col → stack children vertically
    items-center  → center everything horizontally
    gap-6         → space between children (1.5rem)
  -->

      <!-- ===== HEADER ===== -->
      <div class="text-center">
        <!-- Cross icon from Font Awesome -->
        <i class="fa-solid fa-cross text-amber-600 text-3xl mb-3 block"></i>
        <!--
        text-amber-600 → warm gold color for the cross
        text-3xl       → icon size
        mb-3           → margin bottom (space below)
        block          → makes the icon sit on its own line
      -->

        <h1
          style="font-family: 'Cormorant Garamond', serif"
          class="text-3xl font-semibold text-stone-800 leading-tight"
        >
          St. Martin De Porres Catholic Church
        </h1>
        <!-- We use inline style for custom font since Tailwind doesn't include it by default -->

        <a
          href="https://maps.app.goo.gl/9RL5G6jsLWBL75K8A"
          target="_blank"
          rel="noopener"
          class="text-sm text-stone-400 mt-1 tracking-wide italic hover:text-amber-600 transition-colors duration-200"
          style="font-family: 'Cormorant Garamond', serif"
        >
          <i class="fa-solid fa-location-dot text-xs mr-1"></i>
          Taylorsville, Utah
        </a>

        <!-- Gold divider line -->
        <a
          href="tel:+18019682369"
          class="text-sm text-stone-400 mt-2 tracking-wide hover:text-amber-600 transition-colors duration-200 block"
        >
          <i class="fa-solid fa-phone text-xs mr-1"></i>
          (801) 968-2369
        </a>
        <div class="mx-auto mt-3 h-px w-16 bg-amber-400 opacity-60"></div>
        <!--
        mx-auto  → center the div horizontally
        mt-3     → margin top
        h-px     → height = 1px (thin line)
        w-16     → width = 4rem
        bg-amber-400 → gold color
        opacity-60   → slightly transparent
      --></div>

      <!-- ===== SOCIAL LINKS SECTION ===== -->
      <div class="w-full flex flex-col gap-3">
        <!-- Section label -->
        <p class="text-xs text-stone-400 uppercase tracking-widest text-center">
          Connect With Us
        </p>

        <!-- FACEBOOK -->
        <a
          href="https://www.facebook.com/profile.php?id=61580202283712&mibextid=wwXlfr"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 bg-white border border-stone-100 rounded-2xl px-5 py-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
        >
          <!--
        flex items-center gap-4 → icon, text, arrow in a row with spacing
        bg-white                → white card background
        border border-stone-100 → very subtle border
        rounded-2xl             → nicely rounded corners
        px-5 py-4               → padding inside the card
        shadow-sm               → subtle drop shadow
        hover:shadow-md         → bigger shadow on hover
        hover:-translate-y-0.5 → card lifts slightly on hover
        transition-all duration-200 → smooth animation
        no-underline            → remove default link underline
      -->

          <!-- Icon box -->
          <div
            class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-brands fa-facebook-f text-blue-600"></i>
          </div>

          <!-- Text -->
          <div class="flex-1">
            <p class="text-xs text-stone-400 uppercase tracking-wider">
              Social
            </p>
            <p
              class="text-base font-semibold text-stone-700"
              style="font-family: 'Cormorant Garamond', serif"
            >
              Parish Facebook
            </p>
          </div>

          <!-- Arrow -->
          <i class="fa-solid fa-arrow-right text-amber-400 text-sm"></i>
        </a>

        <!-- CHURCH INSTAGRAM -->
        <a
          href="https://www.instagram.com/smdptaylorsville/"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 bg-white border border-stone-100 rounded-2xl px-5 py-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
        >
          <div
            class="w-10 h-10 rounded-xl bg-pink-50 flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-brands fa-instagram text-pink-500"></i>
          </div>
          <div class="flex-1">
            <p class="text-xs text-stone-400 uppercase tracking-wider">
              Social
            </p>
            <p
              class="text-base font-semibold text-stone-700"
              style="font-family: 'Cormorant Garamond', serif"
            >
              Parish Instagram
            </p>
          </div>
          <i class="fa-solid fa-arrow-right text-amber-400 text-sm"></i>
        </a>

        <!-- YOUTH GROUP INSTAGRAM -->
        <a
          href="https://www.instagram.com/samadepo_yg/"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 bg-white border border-stone-100 rounded-2xl px-5 py-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
        >
          <div
            class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-brands fa-instagram text-purple-500"></i>
          </div>
          <div class="flex-1">
            <p class="text-xs text-stone-400 uppercase tracking-wider">
              Youth Group
            </p>
            <p
              class="text-base font-semibold text-stone-700"
              style="font-family: 'Cormorant Garamond', serif"
            >
              SaMaDeP Youth Instagram
            </p>
          </div>
          <i class="fa-solid fa-arrow-right text-amber-400 text-sm"></i>
        </a>
      </div>

      <!-- ===== GIVING SECTION ===== -->
      <div class="w-full flex flex-col gap-3">
        <p class="text-xs text-stone-400 uppercase tracking-widest text-center">
          Support Our Parish
        </p>

        <!-- SUNDAY OFFERTORY -->
        <a
          href="https://www.givecentral.org/customizable-online-giving/1250/event/28636"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 bg-emerald-50 border border-emerald-100 rounded-2xl px-5 py-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
        >
          <div
            class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-solid fa-heart text-emerald-600"></i>
          </div>
          <div class="flex-1">
            <p class="text-xs text-emerald-500 uppercase tracking-wider">
              Weekly
            </p>
            <p
              class="text-base font-semibold text-emerald-800"
              style="font-family: 'Cormorant Garamond', serif"
            >
              Sunday Offertory
            </p>
          </div>
          <i class="fa-solid fa-arrow-right text-emerald-400 text-sm"></i>
        </a>

        <!-- BUILDING FUND -->
        <a
          href="https://www.givecentral.org/customizable-online-giving/1250/event/29543"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 bg-emerald-50 border border-emerald-100 rounded-2xl px-5 py-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
        >
          <div
            class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-solid fa-church text-emerald-600"></i>
          </div>
          <div class="flex-1">
            <p class="text-xs text-emerald-500 uppercase tracking-wider">
              Fund
            </p>
            <p
              class="text-base font-semibold text-emerald-800"
              style="font-family: 'Cormorant Garamond', serif"
            >
              Building Fund
            </p>
          </div>
          <i class="fa-solid fa-arrow-right text-emerald-400 text-sm"></i>
        </a>

        <!-- DIOCESAN DEVELOPMENT -->
        <a
          href="https://www.givecentral.org/customizable-online-giving/1250/event/29544"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 bg-emerald-50 border border-emerald-100 rounded-2xl px-5 py-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
        >
          <div
            class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-solid fa-hand-holding-heart text-emerald-600"></i>
          </div>
          <div class="flex-1">
            <p class="text-xs text-emerald-500 uppercase tracking-wider">
              Diocese
            </p>
            <p
              class="text-base font-semibold text-emerald-800"
              style="font-family: 'Cormorant Garamond', serif"
            >
              Diocesan Development Drive
            </p>
          </div>
          <i class="fa-solid fa-arrow-right text-emerald-400 text-sm"></i>
        </a>
      </div>

      <!-- ===== FOOTER / BIBLE VERSE ===== -->
      <div class="text-center px-4 mt-2">
        <!-- EJS OUTPUT TAG: <%= %> prints a variable's value into the HTML
           verseText and verseRef were passed from app.js via res.render()
           The server already fetched the verse BEFORE sending this page
           So unlike our old version, no JavaScript fetch needed in the browser! -->

        <p
          class="text-sm italic text-stone-500"
          style="font-family: 'Cormorant Garamond', serif"
        >
          "<%= verseText %>"
        </p>

        <p class="text-xs text-stone-400 mt-1 tracking-wide">
          — <%= verseRef %>
        </p>

        <p class="text-xs text-stone-300 mt-4 tracking-wider uppercase">
          © 2026 St. Martin De Porres Catholic Church
        </p>
      </div>
    </div>
  </body>
</html>
